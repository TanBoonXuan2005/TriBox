# Copy this file to client/.env (or client/.env.local) and fill in real values.
# Vite only exposes vars prefixed with VITE_ to the client bundle.

# Backend API base URL.
#   Dev:                 leave EMPTY — Vite proxies /api to the backend (port 3000).
#   Same-origin prod:    leave EMPTY — Express serves client + /api from one origin.
#   Split prod (Vercel + Render on different domains, no rewrite):
#                        https://<render-app>.onrender.com
VITE_API_URL=

# Supabase project — used by the browser client for auth.
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=
