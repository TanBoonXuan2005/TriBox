# Copy this file to .env and fill in real values. Never commit .env.
# These are the backend (server.js) environment variables.

# ── Core ────────────────────────────────────────────────────────────────────
PORT=3000                              # port Express listens on (Render sets this automatically)
NODE_ENV=development                   # "production" enables serving client/dist from this server
APP_URL=http://localhost:5173          # frontend origin; used for Stripe redirects AND /api/* CORS allow-list

# ── Database (Supabase Postgres) ────────────────────────────────────────────
DATABASE_URL=postgres://user:password@localhost:5432/trinode  # Supabase pooler connection string in prod

# ── Supabase (auth: verifies frontend Bearer tokens) ────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=                     # Supabase anon/public key

# ── AI ──────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=                        # Google Generative AI (Gemini) key for /api/chat

# ── Stripe (test mode keys shown; use live keys in prod) ────────────────────
STRIPE_SECRET_KEY=sk_test_...          # secret API key
STRIPE_PRICE_ID=price_...              # recurring $29/mo Pro price id
STRIPE_WEBHOOK_SECRET=whsec_...        # signing secret for /api/stripe-webhook
