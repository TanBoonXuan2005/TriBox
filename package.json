{
  "name": "trinode",
  "version": "1.0.0",
  "description": "Embeddable AI chat widget backend",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "node test/render.test.js && node test/publish.test.js",
    "build:client": "npm install --include=dev --prefix client && npm run build --prefix client",
    "build:widget": "npm install --include=dev --prefix widget && npm run build --prefix widget",
    "build": "npm run build:client && npm run build:widget"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.106.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet": "^7.1.0",
    "pg": "^8.12.0",
    "stripe": "^22.2.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
